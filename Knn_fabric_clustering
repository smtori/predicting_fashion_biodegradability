"""
Clustering fabric with KNN modeling. This model takes in garment data from a Zara item catalog, which is a
popular fast fashion retailer. The model sorts a garment based on it's fabric compositon into one of four categories:
Natural, Synthetic, Blend - Mostly Natural, and Blend - Mostly Synthetic. 

The parameters for fabric composition are:
    material_cols = ['Acrylic', 'Camel Hair', 'Cotton', 'Cupro',
                     'Elastane (Spandex)', 'Linen', 'Lyocell (Tencel)',
                     'Metallic Fiber', 'Modal', 'Nylon',
                     'Polyamide (Nylon)', 'Polyester', 'Viscose (Rayon)', 'Wool']
"""
import pandas as pd
import numpy as np
import statistics
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import f1_score, accuracy_score, classification_report


path = "/Users/torismith/Desktop/DS2500/zara_knn_ready_4cat.csv"
df = pd.read_csv(path)


class KNN():
    """K-Nearest Neighbors classifier implemented"""

    def __init__(self, k):
        """Initialize the KNN model."""
        self.k = k

    def fit(self, X, y):
        """Store training data and labels."""
        self.X_train = X
        self.y_train = y

    def euclidean_distance(self, x1, x2):
        """Calculate Euclidean distance."""
        return np.linalg.norm(np.array(x1) - np.array(x2))

    def compute_distances(self, x):
        """Compute distances from x to all training points."""
        distances = []
        for i in range(len(self.X_train)):
            dist = self.euclidean_distance(x, self.X_train[i])
            label = self.y_train[i]
            distances.append((dist, label))
        return distances

    def get_kneighbors(self, distances):
        """Returns only K closest entries from list of tuples."""
        def get_distance(pair):
            return pair[0]
        sorted_distances = sorted(distances, key=get_distance)
        return sorted_distances[:self.k]

    def classification(self, k_nearest):
        """Return the most common label among k nearest neighbors."""
        labels = []
        for i in range(len(k_nearest)):
            labels.append(k_nearest[i][1])
        return statistics.mode(labels)

    def predict_single(self, x):
        """Predict the label for a single data point."""
        distances = self.compute_distances(x)
        k_nearest = self.get_kneighbors(distances)
        return self.classification(k_nearest)

    def predict(self, X):
        """Predict labels for multiple data points."""
        predictions = []
        for i in range(len(X)):
            pred = self.predict_single(X[i])
            predictions.append(pred)
        return predictions


def split_data(df):
    """
    Splits dataset into training, validation, and test sets using 80/20 splits.
    Parameter: df, DataFrame
    """
    X = df.drop(columns=['material_category'])
    y = df['material_category']

    X_temp, X_test, y_temp, y_test = train_test_split(
        X, y, test_size=0.2, random_state=2500
    )

    X_train, X_val, y_train, y_val = train_test_split(
        X_temp, y_temp, test_size=0.2, random_state=2500
    )

    return X_train, X_val, X_test, y_train, y_val, y_test


def feature_selection(X_train, X_val, X_test, columns):
    """
    Select specific features from the training, validation, and test sets.
    """
    return X_train[columns], X_val[columns], X_test[columns]


def main():
    # Split data
    print("Splitting Data")
    X_train, X_val, X_test, y_train, y_val, y_test = split_data(df)
    print(f"Training set: {len(X_train)} samples")
    print(f"Validation set: {len(X_val)} samples")
    print(f"Test set: {len(X_test)} samples")

    # Feature selection of only the material composition columns
    print("\nFeature Selection")
    material_cols = ['Acrylic', 'Camel Hair', 'Cotton', 'Cupro',
                     'Elastane (Spandex)', 'Linen', 'Lyocell (Tencel)',
                     'Metallic Fiber', 'Modal', 'Nylon',
                     'Polyamide (Nylon)', 'Polyester', 'Viscose (Rayon)', 'Wool']

    X_train_sel, X_val_sel, X_test_sel = feature_selection(
        X_train, X_val, X_test, material_cols)

    # Scale features
    print("\nScaling Features")
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train_sel)
    X_val_scaled = scaler.transform(X_val_sel)
    X_test_scaled = scaler.transform(X_test_sel)

    # Convert y to numpy arrays
    y_train = y_train.values
    y_val = y_val.values
    y_test = y_test.values

    # Find best k using validation set
    print("\nFinding Best K")
    best_k = 1
    best_f1 = 0

    for k in range(1, 31, 2):
        model = KNN(k)
        model.fit(X_train_scaled, y_train)
        preds = model.predict(X_val_scaled)
        score = f1_score(y_val, preds, average='weighted')
        print(f"k = {k}  F1 = {score:.4f}")
        if score > best_f1:
            best_f1 = score
            best_k = k

    print(f"\nBest k: {best_k}, Best F1: {best_f1:.4f}")

    # Train final model with best k and evaluate on test set
    print("\nEvaluating on Test Set")
    final_model = KNN(best_k)
    final_model.fit(X_train_scaled, y_train)
    test_preds = final_model.predict(X_test_scaled)

    # Accuracy
    test_acc = accuracy_score(y_test, test_preds)
    print(f"Test Accuracy: {test_acc:.4f}")

    # F1 Score
    test_f1 = f1_score(y_test, test_preds, average='weighted')
    print(f"Test F1 Score (weighted): {test_f1:.4f}")

    # Full classification report
    print("\nClassification Report:")
    print(classification_report(y_test, test_preds))

    # Example: predict a new garment
    # 60% Cotton, 40% Polyester
    print("\nExample Prediction:")
    new_garment = [0, 0, 60, 0, 0, 0, 0, 0, 0, 0, 0, 40, 0, 0]
    new_garment_scaled = scaler.transform([new_garment])[0]
    prediction = final_model.predict_single(new_garment_scaled)
    print(f"60% Cotton / 40% Polyester -> {prediction}")


if __name__ == "__main__":
    main()